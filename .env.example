# --- Simulation horizon ---
T_SIM=20.0
DT=0.01
F_MAX=0.005

# --- Noise configuration ---
# Use external to read seismic ASD statistics from noise/asd_tools.py.
NOISE_MODEL=external
# For synthetic modes, NOISE_STD is pivot MOTION standard deviation in meters.
NOISE_STD=2e-6
NOISE_FMIN=0.1
NOISE_FMAX=5.0
NOISE_DIR=noise
EXTERNAL_NOISE_GAIN=1.0
EXTERNAL_NOISE_REMOVE_MEAN=1
EXTERNAL_SAMPLE_RATE_HZ=256.0

# --- RL training ---
TOTAL_TIMESTEPS=500000
RUN_REG_TEST=1
CASCADE_MODE=none
CASCADE_ALPHA=1.0

# --- Reward shaping ---
W_X2=1.0
W_X2DOT=0.0
W_U=0.002
W_DU=0.002
TERMINATION_PENALTY=2.0
NOISE_FREE_EP_PROB=0.1
REWARD_MODE=log_multiplicative
ERR_REF_X2=0.001
CTRL_REF_U=1.0

# --- Artifacts ---
ARTIFACTS_DIR=artifacts

# --- Weights & Biases ---
USE_WANDB=0
WANDB_PROJECT=pendulum-sim
WANDB_ENTITY=
WANDB_GROUP=rl_vs_lqr


# --- RL reward bands (frequency-domain only) ---
BAND_LOW_MAX_HZ=5.0
BAND_MID_MIN_HZ=5.0
BAND_MID_MAX_HZ=10.0
STABILITY_MAX_RATIO=3.0
BAND_HIGH_MIN_HZ=10.0
BAND_HIGH_MAX_HZ=30.0
REWARD_FFT_WINDOW=256
REWARD_BASELINE_EPS=1e-12
REWARD_MIN_BASELINE=1e-7
REWARD_SCALE=0.01
REWARD_CTRL_REF_ASD=1e-6


# PPO defaults (stable low-action exploration)
PPO_N_STEPS=1024
PPO_LEARNING_RATE=1e-4
PPO_GAMMA=0.999
PPO_GAE_LAMBDA=0.98
PPO_ENT_COEF=0.005
PPO_LOG_STD_INIT=-1.0
