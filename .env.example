# --- Simulation horizon ---
T_SIM=20.0
DT=0.01
F_MAX=0.005

# --- Noise configuration ---
# Use external to read seismic ASD statistics from noise/asd_tools.py.
NOISE_MODEL=external
NOISE_STD=2e-6
NOISE_FMIN=0.1
NOISE_FMAX=5.0
NOISE_DIR=noise
EXTERNAL_NOISE_GAIN=1.0
EXTERNAL_NOISE_REMOVE_MEAN=1
EXTERNAL_ASD_KIND=displacement

# --- RL training ---
TOTAL_TIMESTEPS=500000
RUN_REG_TEST=1
CASCADE_MODE=none
CASCADE_ALPHA=1.0

# --- Reward shaping ---
W_X2=1.0
W_X2DOT=0.0
W_U=0.002
W_DU=0.002
TERMINATION_PENALTY=2.0
NOISE_FREE_EP_PROB=0.1
REWARD_MODE=log_multiplicative
ERR_REF_X2=0.001
CTRL_REF_U=1.0

# --- Artifacts ---
ARTIFACTS_DIR=artifacts

# --- Weights & Biases ---
USE_WANDB=0
WANDB_PROJECT=pendulum-sim
WANDB_ENTITY=
WANDB_GROUP=rl_vs_lqr

