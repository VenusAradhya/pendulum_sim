# --- Simulation horizon ---
T_SIM=20.0
DT=0.01
F_MAX=0.005

# --- Noise configuration ---
# Use external to read seismic ASD statistics from noise/asd_tools.py.
NOISE_MODEL=external
# For synthetic modes, NOISE_STD is pivot MOTION standard deviation in meters.
NOISE_STD=2e-6
NOISE_FMIN=0.1
NOISE_FMAX=5.0
NOISE_DIR=noise
EXTERNAL_NOISE_GAIN=1.0
EXTERNAL_NOISE_REMOVE_MEAN=1
EXTERNAL_SAMPLE_RATE_HZ=256.0

# --- RL training ---
TOTAL_TIMESTEPS=2000000
RUN_REG_TEST=1
CASCADE_MODE=none
CASCADE_ALPHA=1.0

# --- PPO hyperparameters ---
# LOG_STD_INIT=-1.0 gives initial action std of e^{-1} ≈ 0.37 in pre-tanh space,
# allowing the agent to explore meaningful force magnitudes from the start.
# The previous value of -5.0 (std ≈ 0.007) caused the agent to start near
# zero force, making the zero-force local minimum unreachable to escape.
PPO_LOG_STD_INIT=-1.0
# Small entropy bonus prevents the policy collapsing back to zero force
# once it briefly explores and gets a bad reward signal.
PPO_ENT_COEF=0.001
PPO_N_STEPS=1024
PPO_LEARNING_RATE=1e-4
PPO_GAMMA=0.999
PPO_GAE_LAMBDA=0.98

# --- Reward shaping ---
W_X2=1.0
W_X2DOT=0.0
W_U=0.002
W_DU=0.002
TERMINATION_PENALTY=2.0
NOISE_FREE_EP_PROB=0.1
REWARD_MODE=log_multiplicative
ERR_REF_X2=0.001
CTRL_REF_U=1.0

# --- Artifacts ---
ARTIFACTS_DIR=artifacts

# --- Weights & Biases ---
USE_WANDB=0
WANDB_PROJECT=pendulum-sim
WANDB_ENTITY=
WANDB_GROUP=rl_vs_lqr
